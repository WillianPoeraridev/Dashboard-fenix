generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
  schemas  = ["comercial", "retencao", "shared", "public"]
}

// ========================
// Auth (schema public)
// ========================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("GERENTE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}

// ========================
// SHARED
// ========================

model Customer {
  id              String  @id @default(cuid())
  cpfCnpj         String  @unique
  nome            String
  contatoPrimario String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("shared")
}

// ========================
// COMERCIAL
// ========================

enum Regiao {
  MATRIZ
  LITORAL
  SINOS
  FORA_AREA

  @@schema("comercial")
}

model Venda {
  id            String    @id
  competenciaId String
  data          DateTime?
  definicao     String
  nomeCliente   String
  regiao        Regiao
  valorCents    Int?
  customerId    String?
  vendedorId    String

  @@schema("comercial")
}

model LeadCarteira {
  id          String   @id
  nomeCliente String
  vendedorId  String
  customerId  String?
  createdAt   DateTime

  @@schema("comercial")
}

// ========================
// RETENCAO
// ========================

enum StatusRetencao {
  CANCELADO
  RETIDO
  INADIMPLENCIA

  @@schema("retencao")
}

enum MotivoCancelamento {
  INSATISFACAO_ATD
  INSATISFACAO_SERVICO
  MUDANCA_ENDERECO
  MOTIVOS_PESSOAIS
  TROCA_PROVEDOR
  PROBLEMAS_FINANC
  OUTROS
  INADIMPLENCIA_90

  @@schema("retencao")
}

enum RegiaoRetencao {
  SINOS
  LITORAL
  MATRIZ

  @@map("Regiao")
  @@schema("retencao")
}

model SolicitacaoRetencao {
  id           String    @id
  nomeCliente  String
  status       StatusRetencao
  motivo       MotivoCancelamento?
  regiao       RegiaoRetencao
  ticketCents  Int?
  customerId   String?
  dataRegistro DateTime  @default(now())

  @@schema("retencao")
}