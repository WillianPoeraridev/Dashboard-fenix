generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
  schemas  = ["comercial", "retencao", "shared", "public"]
}

// ========================
// Auth (schema public)
// ========================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("GERENTE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}

// Rate limiting do login: registra só tentativas que FALHARAM (por IP+email).
// Tabela criada manualmente via SQL aditivo (nunca db push neste app).
model LoginAttempt {
  id        BigInt   @id @default(autoincrement())
  key       String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([key, createdAt])
  @@map("LoginAttempt")
  @@schema("public")
}

// Inputs manuais de Marketing (gerência). Tabela própria do Dashboard, criada via
// SQL aditivo (nunca db push). RLS ligada sem policy; leitura/escrita só server-side.
model MarketingInvestimento {
  id         BigInt   @id @default(autoincrement())
  ano        Int
  mes        Int
  canal      String   // valor de OrigemLead (ex: "ADS")
  valorCents Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([ano, mes, canal])
  @@map("MarketingInvestimento")
  @@schema("public")
}

// Custos globais por competência (custo da equipe comercial, etc.).
model CustoMensal {
  id                        BigInt   @id @default(autoincrement())
  ano                       Int
  mes                       Int
  custoEquipeComercialCents Int      @default(0)
  updatedAt                 DateTime @updatedAt

  @@unique([ano, mes])
  @@map("CustoMensal")
  @@schema("public")
}

// ========================
// SHARED
// ========================

model Customer {
  id              String  @id @default(cuid())
  cpfCnpj         String  @unique
  nome            String
  contatoPrimario String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("shared")
}

// ========================
// COMERCIAL
// ========================

enum Regiao {
  MATRIZ
  LITORAL
  SINOS
  FORA_AREA

  @@schema("comercial")
}

// Enums lidos (SELECT) nos shadow models precisam existir aqui senão o Prisma
// falha com P2032. Espelham os enums reais do CRM Comercial.
enum DefinicaoVenda {
  VENDA
  LEAD
  INV_REGIAO
  INV_PORTE
  INV_INADIMPLENCIA

  @@schema("comercial")
}

enum OrigemLead {
  ADS
  INDICACAO
  JA_FOI_CLIENTE
  MELHOR_PLANO
  REDE_NEUTRA
  TERCEIRIZADAS
  MIDIAS_EXTERNAS
  SEGUNDO_PONTO
  NEXE
  MIGRACAO

  @@schema("comercial")
}

enum StatusInstalacao {
  PENDENTE
  SIM
  AGENDADO
  CANCELADO

  @@schema("comercial")
}

model Venda {
  id               String           @id
  competenciaId    String
  data             DateTime?
  definicao        DefinicaoVenda
  nomeCliente      String
  origemLead       OrigemLead
  regiao           Regiao
  cidadeId         String
  valorCents       Int?
  statusInstalacao StatusInstalacao
  customerId       String?
  vendedorId       String

  @@schema("comercial")
}

model LeadCarteira {
  id          String   @id
  nomeCliente String
  vendedorId  String
  customerId  String?
  createdAt   DateTime

  @@schema("comercial")
}

// Shadow model só-leitura do User do CRM Comercial (usado pelo portal de login
// central pra validar credencial e rotear). Campos subset; `role` é omitido de
// propósito (o setor vem de QUAL tabela tem o email — evita ler o enum/P2032).
model ComercialUser {
  id           String  @id
  name         String
  email        String  @unique
  passwordHash String
  isActive     Boolean

  @@map("User")
  @@schema("comercial")
}

// Shadow read-only da Competencia do CRM Comercial (metas/projeções do dashboard).
model ComercialCompetencia {
  id                    String @id
  ano                   Int
  mes                   Int
  metaFinanceiraGeral   Int?
  metaInstalacaoGeral   Int?
  metaFinanceiraMatriz  Int?
  metaFinanceiraLitoral Int?
  metaFinanceiraSinos   Int?
  diasUteis             Int?
  diasTrabalhados       Int?
  metaCancelamentoPct   Float?

  @@unique([ano, mes])
  @@map("Competencia")
  @@schema("comercial")
}

// Shadow read-only das metas por vendedor.
model MetaVendedor {
  id             String @id
  competenciaId  String
  vendedorId     String
  metaFinanceira Int?
  metaInstalacao Int?

  @@map("MetaVendedor")
  @@schema("comercial")
}

// Shadow read-only das cidades do comercial (Top Cidades).
model ComercialCidade {
  id   String @id
  nome String

  @@map("Cidade")
  @@schema("comercial")
}

// ========================
// RETENCAO
// ========================

enum StatusRetencao {
  CANCELADO
  RETIDO
  INADIMPLENCIA

  @@schema("retencao")
}

enum MotivoCancelamento {
  INSATISFACAO_ATD
  INSATISFACAO_SERVICO
  MUDANCA_ENDERECO
  MOTIVOS_PESSOAIS
  TROCA_PROVEDOR
  PROBLEMAS_FINANC
  OUTROS
  INADIMPLENCIA_90

  @@schema("retencao")
}

enum RegiaoRetencao {
  SINOS
  LITORAL
  MATRIZ

  @@map("Regiao")
  @@schema("retencao")
}

model SolicitacaoRetencao {
  id            String    @id
  competenciaId String
  nomeCliente   String
  status        StatusRetencao
  motivo        MotivoCancelamento?
  regiao        RegiaoRetencao
  cidade        String
  ticketCents   Int?
  atendenteId   String
  customerId    String?
  dataRegistro  DateTime  @default(now())

  @@schema("retencao")
}

// Shadow model só-leitura do User do CRM Retenção (portal de login central).
// Mesmo padrão do ComercialUser: subset de campos, `role` omitido.
model RetencaoUser {
  id           String  @id
  name         String
  email        String  @unique
  passwordHash String
  isActive     Boolean

  @@map("User")
  @@schema("retencao")
}

// Shadow read-only da Competencia do CRM Retenção (metas/comissão do dashboard).
model RetencaoCompetencia {
  id                     String @id
  ano                    Int
  mes                    Int
  metaCancelamentos      Int?
  orcamentoComissaoCents Int?
  baseAtivosTotal        Int?
  diasUteis              Int?
  diasTrabalhados        Int?
  metaDiariaManual       Int?

  @@unique([ano, mes])
  @@map("Competencia")
  @@schema("retencao")
}

// Shadow read-only das cidades da retenção (nome legível por id).
model RetencaoCidade {
  id   String @id
  nome String

  @@map("Cidade")
  @@schema("retencao")
}